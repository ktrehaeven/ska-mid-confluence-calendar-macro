<atlassian-plugin key="${atlassian.plugin.key}" name="${project.name}" plugins-version="2">
    <plugin-info>
        <description>${project.description}</description>
        <version>${project.version}</version>
        <vendor name="${project.organization.name}" url="${project.organization.url}" />
        <param name="plugin-icon">images/pluginIcon.png</param>
        <param name="plugin-logo">images/pluginLogo.png</param>
    </plugin-info>

    <resource type="i18n" name="i18n" location="ska-low-confluence-calendar-macro"/>
    
    <!-- add our web resources -->
    <web-resource key="leaflet-resources" name="Leaflet Resources">
        <resource type="download" name="leaflet.css" location="/leaflet/leaflet.css"/>
        <resource type="download" name="leaflet.js" location="/leaflet/leaflet.js"/>
        <resource type="download" name="images/" location="/leaflet/images"/>
    </web-resource>

    <web-resource key="daypilot-resources" name="DayPilot Lite Resources">
        <resource type="download" name="daypilot-all.min.js" location="/daypilot/daypilot-all.min.js"/>
    </web-resource>

    <web-resource key="ska-low-confluence-calendar-macro-resources" name="ska-low-confluence-calendar-macro Web Resources">
        
        <resource type="download" name="stationLocations.json" location="/data/stationLocations.json"/>
        <resource type="download" name="ska-low-confluence-calendar-macro.css" location="/css/ska-low-confluence-calendar-macro.css"/>
        <resource type="download" name="station-data-manager.js" location="/js/station-data-manager.js"/>
        <resource type="download" name="event-service.js" location="/js/event-service.js"/>
        <resource type="download" name="map-renderer.js" location="/js/map-renderer.js"/>
        <resource type="download" name="event-form-manager.js" location="/js/event-form-manager.js"/>
        <resource type="download" name="calendar-renderer.js" location="/js/calendar-renderer.js"/>
        <resource type="download" name="ska-low-calendar-macro.js" location="/js/ska-low-calendar-macro.js"/>
        <resource type="download" name="images/" location="/images"/>
    </web-resource>

    <web-resource key="ska-low-bootstrap-js" name="SKA Low Bootstrap JS">
        <dependency>com.skao.confluence.plugins.ska-low-confluence-calendar-macro:ska-low-confluence-calendar-macro-resources</dependency>

        <resource type="download" name="bootstrap.js" location="/js/bootstrap.js"/>
    </web-resource>

    <xhtml-macro name="ska-low-map-macro" class="com.skao.confluence.plugins.macro.SkaLowMap" key='ska-low-map-macro'
        icon = "/download/resources/com.skao.confluence.plugins.ska-low-confluence-calendar-macro:ska-low-confluence-calendar-macro-resources/images/leafletLogo.jpeg">
        <description key="skalowmap.macro.desc"/>
        <category name="formatting"/>
        <parameters/>
    </xhtml-macro>

    <xhtml-macro name="ska-low-station-bookings-macro" class="com.skao.confluence.plugins.macro.SkaLowStationBookings" key='ska-low-station-bookings-macro'
        icon = "/download/resources/com.skao.confluence.plugins.ska-low-confluence-calendar-macro:ska-low-confluence-calendar-macro-resources/images/daypilotLogo.png">
        <description key="skalowstationbookings.macro.desc"/>
        <category name="formatting"/>
        <parameters/>
    </xhtml-macro>
    
</atlassian-plugin>